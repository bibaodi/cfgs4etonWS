{
    /**
     * The following options control the configuration of the Orthanc
     * plugin adding support of WADO and DICOMweb.
     **/

    "DicomWeb" : {
	//for server mode
	"Enable" : true,         // Whether DICOMweb support is enabled
	"Root" : "/dicom-web/",  // Root URI of the DICOMweb API (for QIDO-RS, STOW-RS and WADO-RS)
	"EnableWado" : true,     // Whether WADO-URI (aka. WADO) support is enabled
	"WadoRoot" : "/wado",    // Root URI of the WADO-URI (aka. WADO) API
	"Host" : "localhost:8042",    // Hard-codes the name of the host for subsequent WADO-RS requests
	"Ssl" : false,            // Whether HTTPS should be used for subsequent WADO-RS requests
	//for client mode
	"Servers":{
                "xin1DicomWebSrv":{ //this make client show all instances --eton@260415
                        "Url":"http://192.168.0.241:8042/dicom-web/",
                        "Username":"eton",
                        "Password":"Orthanc.133"
                }
        }

    }
    /*
    Important Notes:
    1. Self‑reference – The Url http://192.168.1.241:8042/dicom-web appears to point back to the same Orthanc instance (assuming 192.168.1.241 is the same machine). This would create a loop if Orthanc tries to query itself. Only define a server here if it’s a different Orthanc instance or a third‑party DICOMweb server.

    2. Trailing slash – The Url above does not end with a slash. The DICOMweb plugin typically expects a trailing slash (e.g., http://192.168.1.241:8042/dicom-web/). Add it to avoid potential issues.

    3. Authentication – The username/password in Servers are for outgoing connections to that remote server. They have no effect on incoming requests to your own Orthanc. Your own server’s authentication is controlled by the top‑level "AuthenticationEnabled" and "RegisteredUsers" settings.
    */
}

